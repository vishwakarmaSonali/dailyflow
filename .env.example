# ============================================================
# DailyFlow Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to Git.
# ============================================================

# ─── API Gateway ────────────────────────────────────────────
GATEWAY_PORT=3000
NODE_ENV=development

# ─── Auth Service ────────────────────────────────────────────
AUTH_SERVICE_PORT=3001
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_minimum_32_characters_change_in_production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
DATABASE_URL_AUTH=postgresql://user:password@localhost:5432/dailyflow_auth

# ─── Habit Service ───────────────────────────────────────────
HABIT_SERVICE_PORT=3002
DATABASE_URL_HABIT=postgresql://user:password@localhost:5432/dailyflow_habit

# ─── Expense Service ─────────────────────────────────────────
EXPENSE_SERVICE_PORT=3003
DATABASE_URL_EXPENSE=postgresql://user:password@localhost:5432/dailyflow_expense

# ─── Analytics Service ───────────────────────────────────────
ANALYTICS_SERVICE_PORT=3004
DATABASE_URL_ANALYTICS=postgresql://user:password@localhost:5432/dailyflow_analytics

# ─── Notification Service ────────────────────────────────────
NOTIFICATION_SERVICE_PORT=3005
DATABASE_URL_NOTIFICATION=postgresql://user:password@localhost:5432/dailyflow_notification
FCM_PROJECT_ID=your_fcm_project_id
FCM_PRIVATE_KEY_ID=your_fcm_key_id
FCM_PRIVATE_KEY=your_fcm_private_key
FCM_CLIENT_EMAIL=your_fcm_client_email

# ─── AI Service (Python/FastAPI) ─────────────────────────────
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://localhost:8000
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4-vision-preview
OPENAI_WHISPER_MODEL=whisper-1

# ─── Redis / BullMQ ──────────────────────────────────────────
# Local Docker: redis://localhost:6379
# Upstash (cloud): rediss://user:password@host:6379
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
UPSTASH_REDIS_URL=redis://user:password@redis-host:port

# ─── Web Dashboard (Vite) ────────────────────────────────────
VITE_API_URL=http://localhost:3000/api
VITE_APP_VERSION=1.0.0

# ─── Expo Mobile App ─────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=debug

# ─── CI/CD Secrets (set in GitHub Settings → Secrets, not here) ──
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=

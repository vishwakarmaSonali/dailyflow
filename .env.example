# ===== API GATEWAY =====
GATEWAY_PORT=3000
NODE_ENV=development

# ===== AUTH SERVICE =====
AUTH_SERVICE_PORT=3001
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
DATABASE_URL_AUTH=postgresql://user:password@localhost:5432/dailyflow_auth

# ===== HABIT SERVICE =====
HABIT_SERVICE_PORT=3002
DATABASE_URL_HABIT=postgresql://user:password@localhost:5432/dailyflow_habit

# ===== EXPENSE SERVICE =====
EXPENSE_SERVICE_PORT=3003
DATABASE_URL_EXPENSE=postgresql://user:password@localhost:5432/dailyflow_expense

# ===== ANALYTICS SERVICE =====
ANALYTICS_SERVICE_PORT=3004
DATABASE_URL_ANALYTICS=postgresql://user:password@localhost:5432/dailyflow_analytics

# ===== NOTIFICATION SERVICE =====
NOTIFICATION_SERVICE_PORT=3005
DATABASE_URL_NOTIFICATION=postgresql://user:password@localhost:5432/dailyflow_notification
FCM_PROJECT_ID=your_fcm_project_id
FCM_PRIVATE_KEY_ID=your_fcm_key_id
FCM_PRIVATE_KEY=your_fcm_private_key
FCM_CLIENT_EMAIL=your_fcm_client_email

# ===== AI SERVICE =====
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://localhost:8000
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4-vision-preview
OPENAI_WHISPER_MODEL=whisper-1

# ===== REDIS / BULLMQ =====
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
UPSTASH_REDIS_URL=redis://user:password@redis-host:port

# ===== LOGGING =====
LOG_LEVEL=debug

{
  "name": "dailyflow",
  "version": "0.1.0",
  "description": "Enterprise personal productivity platform with microservices architecture",
  "private": true,
  "scripts": {
    "dev": "npm -r --parallel run dev",
    "build": "npm -r --filter=\"./apps/**\" build",
    "test": "npm -r test",
    "test:coverage": "npm -r test:coverage",
    "lint": "eslint \"**/*.{ts,tsx,js}\" --ignore-pattern=\"node_modules/\"",
    "lint:fix": "eslint \"**/*.{ts,tsx,js}\" --fix --ignore-pattern=\"node_modules/\"",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "prepare": "husky install"
  },
  "keywords": [
    "habit-tracking",
    "expense-management",
    "microservices",
    "clean-architecture"
  ],
  "author": "DailyFlow Team",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "commitlint": "^18.6.1",
    "eslint": "^10.4.0",
    "husky": "^8.0.3",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
